{
  "name": "collabbridge-backend",
  "version": "1.0.0",
  "description": "Backend API for CollabBridge - Connecting Event Planners with Creative Professionals",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset.js",
    "logs:clear": "rm -rf logs/*.log",
    "docs": "jsdoc src/**/*.js -d docs"
  },
  "keywords": [
    "events",
    "professionals",
    "collaboration",
    "rwanda",
    "api",
    "express",
    "postgresql",
    "firebase",
    "cloudinary"
  ],
  "author": "Nerd Herd Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^6.7.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.8.2",
    "pg": "^8.11.0",
    "uuid": "^9.0.0",
    "jsonwebtoken": "^9.0.0",
    "firebase-admin": "^11.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.1.4",
    "joi": "^17.9.2",
    "cloudinary": "^1.41.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "sharp": "^0.32.6"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.42.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^2.8.8",
    "jsdoc": "^4.0.2"
  }
}