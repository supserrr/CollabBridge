generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

enum UserRole {
  EVENT_PLANNER
  CREATIVE_PROFESSIONAL
  ADMIN
}

enum EventType {
  WEDDING
  CORPORATE
  BIRTHDAY
  CONCERT
  CONFERENCE
  FESTIVAL
  EXHIBITION
  WORKSHOP
  SEMINAR
  PARTY
  LAUNCH
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  BOOKING_REQUEST
  SYSTEM
}

enum NotificationType {
  BOOKING_REQUEST
  APPLICATION_UPDATE
  REVIEW_RECEIVED
  MESSAGE_RECEIVED
  EVENT_REMINDER
  SYSTEM_ANNOUNCEMENT
  PAYMENT_RECEIVED
  CALENDAR_SYNC
}

enum PromotionType {
  FEATURED_PROFILE
  FEATURED_EVENT
  PREMIUM_LISTING
  BOOST_VISIBILITY
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  PAYPAL
  STRIPE
  OTHER
}

enum ReportReason {
  INAPPROPRIATE_CONTENT
  SPAM
  FALSE_INFORMATION
  HARASSMENT
  FAKE_PROFILE
  SCAM
  COPYRIGHT_VIOLATION
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model User {
  id            String   @id @default(cuid())
  firebaseUid   String   @unique
  email         String   @unique
  name          String
  role          UserRole
  location      String?
  bio           String?
  avatar        String?
  phone         String?
  timezone      String   @default("UTC")
  language      String   @default("en")
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  isOnline      Boolean  @default(false)
  lastActiveAt  DateTime @default(now())
  marketingConsent Boolean @default(false)
  verificationDocs Json?
  socialLinks   Json?
  preferences   Json?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  eventPlanner       EventPlanner?
  creativeProfile    CreativeProfile?
  sentMessages       Message[]        @relation("SentMessages")
  receivedMessages   Message[]        @relation("ReceivedMessages")
  givenReviews      Review[]         @relation("ReviewGiver")
  receivedReviews   Review[]         @relation("ReviewReceiver")
  eventApplications  EventApplication[]
  bookings          Booking[]
  notifications     Notification[]
  promotions        Promotion[]
  activities        UserActivity[]
  favorites         Favorite[]
  reports           Report[]         @relation("Reporter")
  resolvedReports   Report[]         @relation("Resolver")
  conversations     Conversation[]   @relation("ConversationParticipants")

  @@map("users")
  @@index([role, isActive])
  @@index([email])
  @@index([firebaseUid])
  @@index([location])
  @@index([isOnline])
}

model EventPlanner {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  website     String?
  taxId       String?
  businessType String?
  foundedYear Int?
  teamSize    String?
  specialties String[]
  serviceAreas String[]
  description String?
  
  // Relationships
  events      Event[]
  bookings    Booking[]
  templates   EventTemplate[]

  @@map("event_planners")
}

model CreativeProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories        String[] 
  portfolioImages   String[] 
  portfolioLinks    String[] 
  hourlyRate        Float?
  dailyRate         Float?
  projectRate       Float?
  currency          String   @default("USD")
  experience        String?
  equipment         String?
  skills            String[]
  languages         String[]
  availableFrom     DateTime?
  availableTo       DateTime?
  workingHours      Json? 
  isAvailable       Boolean  @default(true)
  responseTime      Int?     // in hours
  travelRadius      Int?     // in kilometers
  willTravel        Boolean  @default(false)
  certifications    String[]
  awards            String[]
  education         String[]
  socialMedia       Json?
  
  // Professional details
  yearsExperience   Int?
  completedProjects Int      @default(0)
  cancellationRate  Float    @default(0.0)
  averageRating     Float    @default(0.0)
  totalReviews      Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  applications      EventApplication[]
  bookings          Booking[]
  receivedReviews   Review[]           @relation("ProfessionalReviews")

  @@map("creative_profiles")
  @@index([categories])
  @@index([skills])
  @@index([isAvailable])
  @@index([hourlyRate])
  @@index([averageRating])
}

model Event {
  id              String      @id @default(cuid())
  eventPlannerId  String
  eventPlanner    EventPlanner @relation(fields: [eventPlannerId], references: [id], onDelete: Cascade)
  title           String
  description     String
  eventType       EventType
  startDate       DateTime
  endDate         DateTime
  location        String
  address         String?
  latitude        Float?
  longitude       Float?
  venue           String?
  budget          Float?
  currency        String      @default("USD")
  estimatedGuests Int?
  requiredRoles   String[]
  tags            String[]
  maxApplicants   Int?
  isPublic        Boolean     @default(true)
  isFeatured      Boolean     @default(false)
  isUrgent        Boolean     @default(false)
  status          EventStatus @default(DRAFT)
  images          String[]
  attachments     Json?
  requirements    String?
  contactInfo     Json?
  applicationDeadline DateTime?
  setupTime       String?
  breakdown       String?
  dressCode       String?
  ageRestriction  String?
  
  // SEO and discovery
  slug            String?     @unique
  viewCount       Int         @default(0)
  applicationCount Int        @default(0)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  applications    EventApplication[]
  bookings        Booking[]
  favorites       Favorite[]
  
  @@map("events")
  @@index([eventType, status])
  @@index([startDate])
  @@index([location])
  @@index([budget])
  @@index([isFeatured])
  @@index([requiredRoles])
  @@index([isPublic, status])
  @@index([tags])
}

model EventApplication {
  id              String            @id @default(cuid())
  eventId         String
  event           Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  professionalId  String
  professional    CreativeProfile   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  message         String?
  proposedRate    Float?
  currency        String?           @default("USD")
  availability    Json?
  portfolio       String[]
  coverLetter     String?
  estimatedHours  Int?
  equipment       String[]
  experience      String?
  status          ApplicationStatus @default(PENDING)
  response        String?
  responseReason  String?
  respondedAt     DateTime?
  withdrawnAt     DateTime?
  withdrawReason  String?
  
  // Tracking
  viewedByPlanner Boolean           @default(false)
  viewedAt        DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("event_applications")
  @@unique([eventId, professionalId])
  @@index([status])
  @@index([createdAt])
  @@index([professionalId])
}

model Booking {
  id              String        @id @default(cuid())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventPlannerId  String
  eventPlanner    EventPlanner  @relation(fields: [eventPlannerId], references: [id], onDelete: Cascade)
  professionalId  String
  professional    CreativeProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  
  // Booking details
  startDate       DateTime
  endDate         DateTime
  setupTime       DateTime?
  breakdownTime   DateTime?
  rate            Float
  rateType        String        @default("hourly") // hourly, daily, project
  currency        String        @default("USD")
  totalAmount     Float?
  deposit         Float?
  depositPaid     Boolean       @default(false)
  
  // Terms and conditions
  description     String?
  requirements    String[]
  deliverables    String[]
  terms           String?
  cancellationPolicy String?
  
  // Status tracking
  status          BookingStatus @default(PENDING)
  confirmedAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  cancelledBy     String?      // userId who cancelled
  
  // Communication
  notes           String?
  privateNotes    String?      // Only visible to event planner
  
  // Documents
  contract        String?       // URL to contract document
  invoice         String?       // URL to invoice
  receipt         String?       // URL to receipt
  
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  payments        Payment[]
  reviews         Review[]

  @@map("bookings")
  @@index([status])
  @@index([startDate])
  @@index([professionalId])
  @@index([eventPlannerId])
  @@index([eventId])
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String        @default("USD")
  paymentMethod   PaymentMethod
  paymentType     String        @default("booking") // booking, deposit, tip
  transactionId   String?
  stripePaymentId String?
  paypalPaymentId String?
  status          String        @default("COMPLETED")
  description     String?
  receiptUrl      String?
  refundAmount    Float?
  refundedAt      DateTime?
  refundReason    String?
  paidAt          DateTime      @default(now())
  metadata        Json?
  createdAt       DateTime      @default(now())

  @@map("payments")
  @@index([bookingId])
  @@index([paidAt])
  @@index([status])
}

model Review {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId      String
  reviewer        User     @relation("ReviewGiver", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId      String
  reviewee        User     @relation("ReviewReceiver", fields: [revieweeId], references: [id], onDelete: Cascade)
  professionalId  String?
  professional    CreativeProfile? @relation("ProfessionalReviews", fields: [professionalId], references: [id], onDelete: SetNull)
  
  // Rating details
  rating          Int      // 1-5 stars overall
  skillsRating    Int?     // 1-5 rating for skills
  communication   Int?     // 1-5 rating for communication
  professionalism Int?     // 1-5 rating for professionalism
  quality         Int?     // 1-5 rating for quality
  timeliness      Int?     // 1-5 rating for timeliness
  value           Int?     // 1-5 rating for value
  
  // Review content
  title           String?
  comment         String
  pros            String[]
  cons            String[]
  skills          String[] // Skills mentioned in review
  wouldRecommend  Boolean  @default(true)
  wouldHireAgain  Boolean? // Only for event planners reviewing professionals
  
  // Review settings
  isPublic        Boolean  @default(true)
  isAnonymous     Boolean  @default(false)
  isVerified      Boolean  @default(false)
  
  // Response from reviewee
  response        String?
  respondedAt     DateTime?
  
  // Helpfulness tracking
  helpfulCount    Int      @default(0)
  reportCount     Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("reviews")
  @@unique([bookingId, reviewerId])
  @@index([revieweeId])
  @@index([rating])
  @@index([createdAt])
  @@index([isPublic])
}

model Conversation {
  id              String    @id @default(cuid())
  participants    User[]    @relation("ConversationParticipants")
  title           String?
  type            String    @default("direct") // direct, group, support
  lastMessageId   String?
  lastMessage     Message?  @relation("LastMessage", fields: [lastMessageId], references: [id])
  lastMessageAt   DateTime  @default(now())
  isArchived      Boolean   @default(false)
  isBlocked       Boolean   @default(false)
  blockedBy       String?   // userId who blocked
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relationships
  messages        Message[] @relation("ConversationMessages")

  @@map("conversations")
  @@index([lastMessageAt])
  @@index([type])
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  // Message content
  content         String
  messageType     MessageType   @default(TEXT)
  attachments     String[]
  fileSize        Int?          // Total size of attachments in bytes
  
  // Status
  isEdited        Boolean       @default(false)
  editedAt        DateTime?
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  readBy          String[]      // Array of user IDs who read this message
  deliveredAt     DateTime?
  
  // Special message data
  bookingData     Json?         // For booking request messages
  systemData      Json?         // For system messages
  
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  lastMessageConversations Conversation[] @relation("LastMessage")

  @@map("messages")
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([messageType])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  icon        String?
  data        Json?
  actionUrl   String?
  isRead      Boolean           @default(false)
  readAt      DateTime?
  isArchived  Boolean           @default(false)
  priority    String            @default("normal") // low, normal, high, urgent
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())

  @@map("notifications")
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([type])
  @@index([priority])
}

model Promotion {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PromotionType
  targetId    String        // ID of event or profile being promoted
  title       String
  description String?
  amount      Float
  currency    String        @default("USD")
  duration    Int           // Duration in days
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean       @default(true)
  isPaused    Boolean       @default(false)
  clicks      Int           @default(0)
  views       Int           @default(0)
  conversions Int           @default(0)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("promotions")
  @@index([type, isActive])
  @@index([startDate, endDate])
  @@index([userId])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // Could add professionalId for favoriting professionals
  type        String   @default("event") // event, professional
  createdAt   DateTime @default(now())

  @@map("favorites")
  @@unique([userId, eventId])
  @@index([userId])
  @@index([type])
}

model UserActivity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   // login, logout, profile_update, event_created, application_sent, etc.
  entity      String?  // Type of entity involved (event, booking, message, etc.)
  entityId    String?  // ID of the entity
  description String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  location    String?
  createdAt   DateTime @default(now())

  @@map("user_activities")
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  String       // USER, EVENT, REVIEW, MESSAGE, etc.
  targetId    String
  reason      ReportReason
  description String?
  evidence    String[]     // URLs to screenshots or other evidence
  status      ReportStatus @default(PENDING)
  priority    String       @default("normal") // low, normal, high, critical
  action      String?      // Action taken by admin
  notes       String?      // Admin notes
  resolvedAt  DateTime?
  resolvedBy  String?
  resolver    User?        @relation("Resolver", fields: [resolvedBy], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("reports")
  @@index([targetType, targetId])
  @@index([status])
  @@index([createdAt])
  @@index([priority])
}

model EventTemplate {
  id              String       @id @default(cuid())
  eventPlannerId  String
  eventPlanner    EventPlanner @relation(fields: [eventPlannerId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  eventType       EventType
  template        Json         // Template data structure
  isPublic        Boolean      @default(false)
  usageCount      Int          @default(0)
  rating          Float        @default(0.0)
  tags            String[]
  thumbnail       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("event_templates")
  @@index([eventType])
  @@index([isPublic])
  @@index([rating])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string") // string, number, boolean, json
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model Analytics {
  id          String   @id @default(cuid())
  type        String   // page_view, event_created, booking_completed, etc.
  entityType  String?  // user, event, booking, etc.
  entityId    String?
  userId      String?
  sessionId   String?
  data        Json?
  ipAddress   String?
  userAgent   String?
  referrer    String?
  createdAt   DateTime @default(now())

  @@map("analytics")
  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}
