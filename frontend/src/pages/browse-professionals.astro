---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Find Creative Professionals - CollabBridge">
  <Header />
  <main class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="bg-white border-b">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
            Find Amazing Creative Professionals
          </h1>
          <p class="mt-4 text-xl text-gray-600">
            Connect with talented photographers, DJs, decorators, and more
          </p>
        </div>
      </div>
    </section>

    <!-- Professionals Section -->
    <section class="py-8 pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div id="professionals-container">
          <!-- React component will be mounted here -->
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { createRoot } from 'react-dom/client';
  import { createElement } from 'react';
  import ProfessionalsSearch from '../components/search/ProfessionalsSearch';

  // Mount professionals component
  const professionalsContainer = document.getElementById('professionals-container');
  if (professionalsContainer) {
    const root = createRoot(professionalsContainer);
    root.render(createElement(ProfessionalsSearch));
  }
</script>
