---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Register - CollabBridge">
  <div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="flex justify-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-600">
          <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.739 9 11 5.16-1.261 9-5.45 9-11V7l-10-5z"/>
          </svg>
        </div>
      </div>
      <h2 class="mt-6 text-center text-3xl font-bold tracking-tight text-gray-900">
        Join CollabBridge
      </h2>
      <p class="mt-2 text-center text-sm text-gray-600">
        Connect with amazing opportunities
      </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
        <div id="register-form-container">
          <!-- React component will be mounted here -->
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createRoot } from 'react-dom/client';
  import RegisterForm from '../components/forms/RegisterForm';

  const container = document.getElementById('register-form-container');
  if (container) {
    const root = createRoot(container);
    root.render(RegisterForm());
  }
</script>
