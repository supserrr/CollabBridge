---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HowItWorks from '../components/HowItWorks.astro';
---

<Layout title="How It Works - CollabBridge">
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-brand-600 to-brand-700 text-white">
      <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
            How CollabBridge Works
          </h1>
          <p class="mt-6 text-xl text-brand-100 max-w-3xl mx-auto">
            Connecting event planners with creative professionals has never been easier. 
            Here's how our platform brings your events to life.
          </p>
        </div>
      </div>
    </section>

    <!-- Process Steps -->
    <HowItWorks />

    <!-- For Event Planners -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            For Event Planners
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Everything you need to find and book the perfect creative team
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-8">
            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Smart Search</h3>
                <p class="mt-2 text-base text-gray-500">
                  Filter by category, location, budget, and availability to find the perfect match for your event.
                </p>
              </div>
            </div>

            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Direct Communication</h3>
                <p class="mt-2 text-base text-gray-500">
                  Chat directly with professionals, share ideas, and coordinate details all in one place.
                </p>
              </div>
            </div>

            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Secure Booking</h3>
                <p class="mt-2 text-base text-gray-500">
                  Book with confidence using our secure platform with built-in contracts and payment protection.
                </p>
              </div>
            </div>
          </div>

          <div class="relative">
            <img 
              class="rounded-lg shadow-lg" 
              src="/images/event-planner-dashboard.jpg" 
              alt="Event Planner Dashboard"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- For Creative Professionals -->
    <section class="py-20 bg-gray-50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            For Creative Professionals
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Grow your business and showcase your talent to a wider audience
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="relative order-2 lg:order-1">
            <img 
              class="rounded-lg shadow-lg" 
              src="/images/creative-profile.jpg" 
              alt="Creative Professional Profile"
            />
          </div>

          <div class="space-y-8 order-1 lg:order-2">
            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Showcase Your Work</h3>
                <p class="mt-2 text-base text-gray-500">
                  Create a stunning portfolio that highlights your best work and attracts your ideal clients.
                </p>
              </div>
            </div>

            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Set Your Rates</h3>
                <p class="mt-2 text-base text-gray-500">
                  Control your pricing, availability, and terms. Get paid fairly for your creative expertise.
                </p>
              </div>
            </div>

            <div class="flex">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-12 w-12 rounded-md bg-brand-500 text-white">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-medium text-gray-900">Grow Your Network</h3>
                <p class="mt-2 text-base text-gray-500">
                  Connect with event planners, build relationships, and get referrals for future projects.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-brand-700">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
            Ready to get started?
          </h2>
          <p class="mt-4 text-xl text-brand-100">
            Join thousands of professionals already using CollabBridge
          </p>
          <div class="mt-8">
            <a 
              href="/auth/register"
              class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-3 text-lg font-semibold text-brand-700 shadow-lg transition-all hover:bg-gray-50 hover:shadow-xl hover:-translate-y-0.5"
            >
              Get Started Free
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
