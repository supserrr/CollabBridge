---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Browse Events - CollabBridge">
  <Header />
  <main class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="bg-white border-b">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
            Discover Amazing Events
          </h1>
          <p class="mt-4 text-xl text-gray-600">
            Find events that match your skills and grow your portfolio
          </p>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section class="py-8">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div id="events-filters-container">
          <!-- React component will be mounted here -->
        </div>
      </div>
    </section>

    <!-- Events Grid -->
    <section class="pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div id="events-grid-container">
          <!-- React component will be mounted here -->
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { createRoot } from 'react-dom/client';
  import { createElement } from 'react';
  import EventsFilters from '../components/events/EventsFilters';
  import EventsGrid from '../components/events/EventsGrid';

  // Mount filters component
  const filtersContainer = document.getElementById('events-filters-container');
  if (filtersContainer) {
    const root = createRoot(filtersContainer);
    root.render(createElement(EventsFilters));
  }

  // Mount grid component
  const gridContainer = document.getElementById('events-grid-container');
  if (gridContainer) {
    const root = createRoot(gridContainer);
    root.render(createElement(EventsGrid));
  }
</script>
