---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Browse Events - CollabBridge">
  <Header />
  <main class="min-h-screen bg-gray-50">
    <!-- Hero Section -->
    <section class="bg-white border-b">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
            Discover Amazing Events
          </h1>
          <p class="mt-4 text-xl text-gray-600">
            Find events that match your skills and grow your portfolio
          </p>
        </div>
      </div>
    </section>

    <!-- Events Section -->
    <section class="py-8 pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div id="events-container">
          <!-- React component will be mounted here -->
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import { createRoot } from 'react-dom/client';
  import { createElement } from 'react';
  import EventsFilters from '../components/events/EventsFilters';

  // Mount events component
  const eventsContainer = document.getElementById('events-container');
  if (eventsContainer) {
    const root = createRoot(eventsContainer);
    root.render(createElement(EventsFilters));
  }
</script>
