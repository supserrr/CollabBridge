---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<Layout title="Terms of Service - CollabBridge">
  <Header />
  <main class="bg-white">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="prose prose-lg mx-auto">
        <h1>Terms of Service</h1>
        <p class="lead">Last updated: {new Date().toLocaleDateString()}</p>
        
        <h2>Acceptance of Terms</h2>
        <p>By accessing and using CollabBridge, you accept and agree to be bound by the terms and provision of this agreement.</p>
        
        <h2>Use License</h2>
        <p>Permission is granted to temporarily use CollabBridge for personal, non-commercial transitory viewing only.</p>
        
        <h2>User Accounts</h2>
        <p>You are responsible for maintaining the confidentiality of your account and password and for restricting access to your computer.</p>
        
        <h2>Prohibited Uses</h2>
        <p>You may not use our service for any illegal or unauthorized purpose nor may you, in the use of the service, violate any laws in your jurisdiction.</p>
        
        <h2>Contact Information</h2>
        <p>Questions about the Terms of Service should be sent to us at legal@collabbridge.com.</p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
