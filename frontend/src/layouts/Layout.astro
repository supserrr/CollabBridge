---
export interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
}

const { 
  title, 
  description = "Connect event planners with talented creative professionals on CollabBridge.", 
  noIndex = false 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Zen Browser Inspired Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/images/og-image.jpg" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/images/og-image.jpg" />
  </head>

  <body class="min-h-screen font-sans antialiased bg-background text-foreground zen-dark-aware">
    <slot />
    
    <!-- Zen Browser Inspired Global Scripts -->
    <script>
      // Zen-style smooth theme transitions
      const enableZenTransitions = () => {
        document.documentElement.style.setProperty('--transition-duration', '200ms');
        document.documentElement.style.setProperty('--transition-timing', 'cubic-bezier(0.4, 0, 0.2, 1)');
      };

      // Enhanced dark mode detection with Zen browser aesthetics
      const initZenTheme = () => {
        const isDarkMode = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const storedTheme = localStorage.getItem('zen-theme');
        
        if (storedTheme === 'dark' || (!storedTheme && isDarkMode)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      // Listen for theme changes with Zen browser smooth transitions
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (!localStorage.getItem('zen-theme')) {
          if (e.matches) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }
      });

      // Initialize Zen theme system
      initZenTheme();
      enableZenTransitions();

      // Zen browser inspired smooth scrolling
      const smoothScrollToElement = (element) => {
        element.scrollIntoView({ 
          behavior: 'smooth', 
          block: 'start',
          inline: 'nearest' 
        });
      };

      // Enhanced focus management for accessibility
      const initZenFocus = () => {
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Tab') {
            document.body.classList.add('zen-keyboard-navigation');
          }
        });

        document.addEventListener('mousedown', () => {
          document.body.classList.remove('zen-keyboard-navigation');
        });
      };

      initZenFocus();

      // Zen browser inspired console message
      console.log('🧘 CollabBridge - Zen Browser Inspired Design System Loaded');
      console.log('🌟 Welcome to a calmer, more productive internet experience');
    </script>
    
    <!-- Integration Checker -->
    <script type="module">
      import { frontendChecker } from '@/utils/integrationChecker';
      
      // Run integration check on page load
      document.addEventListener('DOMContentLoaded', async () => {
        try {
          const results = await frontendChecker.checkAll();
          const score = frontendChecker.getConnectionScore();
          
          if (score === 100) {
            console.log('%c🎉 CollabBridge Frontend - 100% Connected!', 'color: #10b981; font-weight: bold; font-size: 16px;');
          } else if (score >= 90) {
            console.log(`%c✅ CollabBridge Frontend - ${score}% Connected`, 'color: #f59e0b; font-weight: bold; font-size: 14px;');
          } else {
            console.log(`%c⚠️ CollabBridge Frontend - ${score}% Connected`, 'color: #ef4444; font-weight: bold; font-size: 14px;');
          }
          
          // Add score to window for debugging
          window.collabBridgeScore = score;
          window.collabBridgeChecker = frontendChecker;
        } catch (error) {
          console.error('Integration check failed:', error);
        }
      });
    </script>
  </body>
</html>
