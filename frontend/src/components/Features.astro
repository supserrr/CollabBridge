---
const features = [
  {
    icon: '💬',
    title: 'Peaceful Communication',
    description: 'Distraction-free messaging with built-in focus modes, ensuring clear and productive conversations.'
  },
  {
    icon: '📅', 
    title: 'Zen Calendar',
    description: 'Seamless scheduling with intelligent time blocking and gentle reminders that respect your workflow.'
  },
  {
    icon: '⭐',
    title: 'Trust & Transparency', 
    description: 'Build authentic professional relationships through our thoughtful review system and verified profiles.'
  },
  {
    icon: '🌍',
    title: 'Global Harmony',
    description: 'Connect with talent worldwide through our inclusive, multilingual platform that celebrates diversity.'
  },
  {
    icon: '🎯',
    title: 'Mindful Matching',
    description: 'Our thoughtful algorithm connects you with the right creative professionals, reducing noise and focusing on meaningful collaborations.'
  },
  {
    icon: '✨',
    title: 'Mindful Visibility',
    description: 'Ethically promote your work with featured listings that maintain the calm, professional atmosphere.'
  }
];
---

<section style="padding: 6rem 0; background-color: rgba(255, 255, 255, 0.7);">
  <div style="max-width: 72rem; margin: 0 auto; padding: 0 1.5rem;">
    <div style="text-align: center; margin-bottom: 4rem;">
      <h2 style="font-size: 3rem; font-weight: 300; color: #2d2520; margin-bottom: 1.5rem; letter-spacing: -0.025em;">
        A <span style="color: #ef7744; font-style: italic;">Calmer</span> Way to Connect
      </h2>
      <p style="font-size: 1.25rem; color: #6b5f47; max-width: 48rem; margin: 0 auto; line-height: 1.6;">
        Thoughtfully designed features that prioritize meaningful connections and productive collaboration
      </p>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      {features.map((feature) => (
        <div style="background-color: #f4f1eb; border-radius: 1rem; padding: 2rem; border: 1px solid rgba(45, 37, 32, 0.1); transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(45, 37, 32, 0.1);" class="feature-card">
          <div style="font-size: 2.5rem; margin-bottom: 1.5rem;">{feature.icon}</div>
          <h3 style="font-size: 1.25rem; font-weight: 500; color: #2d2520; margin-bottom: 1rem;">{feature.title}</h3>
          <p style="color: #6b5f47; line-height: 1.6;">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Zen Browser inspired hover effects */
  .feature-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 8px 24px rgba(45, 37, 32, 0.15);
    border-color: rgba(239, 119, 68, 0.2);
  }

  /* Performance optimization */
  .feature-card {
    will-change: transform;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    h2 {
      font-size: 2rem !important;
    }
    
    section {
      padding: 4rem 0 !important;
    }
  }

  @media (min-width: 1024px) {
    h2 {
      font-size: 4rem !important;
    }
  }
</style>

<style>
  /* Zen Browser inspired hover effects */
  .feature-card:hover {
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
  }

  /* Performance optimization */
  .feature-card {
    will-change: transform;
  }
</style>

<style>
  /* Zen Browser inspired section styling */
  .zen-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
  }

  .zen-bg-subtle {
    background: linear-gradient(135deg, 
      hsl(var(--background)) 0%, 
      hsl(var(--muted)/0.3) 50%, 
      hsl(var(--background)) 100%
    );
  }

  /* Zen Browser inspired hover effects */
  .zen-hover-accent:hover {
    color: hsl(var(--primary));
    transition: color 0.3s ease;
  }

  /* Zen Browser inspired card enhancements */
  .zen-card {
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .zen-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
  }

  .dark .zen-card:hover {
    box-shadow: 0 20px 40px -12px rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired performance optimization */
  .zen-card * {
    will-change: transform;
  }

  /* Zen Browser inspired responsive design */
  @media (max-width: 768px) {
    .zen-section {
      padding: 4rem 0;
    }
  }

  /* Zen Browser inspired accessibility */
  @media (prefers-reduced-motion: reduce) {
    .zen-animate-in {
      animation: none;
    }
    
    .zen-hover-lift:hover {
      transform: none;
    }
  }
</style>

<script>
  // Zen Browser inspired intersection observer for animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-zen-fade-in');
      }
    });
  }, observerOptions);

  // Observe all feature cards
  document.querySelectorAll('.zen-card').forEach(card => {
    observer.observe(card);
  });

  // Zen Browser inspired smooth scrolling enhancement
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>
