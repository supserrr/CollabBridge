---
const features = [
  'Professional Network',
  'Real-time Messaging',
  'Smart Matching',
  'Global Reach'
];
---

<section class="relative zen-hero zen-gradient overflow-hidden">
  <!-- Zen Browser inspired background elements -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(59,130,246,0.1),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(139,92,246,0.1),transparent_50%)]"></div>
  
  <!-- Zen Browser inspired floating elements -->
  <div class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-r from-primary/10 to-accent/10 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-20 right-10 w-48 h-48 bg-gradient-to-r from-accent/10 to-primary/10 rounded-full blur-3xl animate-float" style="animation-delay: 1s;"></div>
  
  <div class="relative zen-container">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Zen Browser inspired main heading -->
      <h1 class="zen-text-balance mb-6 text-4xl font-bold tracking-tight text-foreground md:text-6xl lg:text-7xl zen-animate-in">
        Welcome to a 
        <span class="zen-gradient-text">Calmer</span> 
        Creative Network
      </h1>
      
      <!-- Zen Browser inspired subtitle -->
      <p class="zen-text-balance mx-auto mb-8 max-w-2xl text-lg text-muted-foreground md:text-xl zen-animate-in" style="animation-delay: 0.1s;">
        Connect event planners with talented creative professionals. 
        Build meaningful collaborations in a peaceful, productivity-focused environment.
      </p>
      
      <!-- Zen Browser inspired CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 zen-animate-in" style="animation-delay: 0.2s;">
        <a href="/auth/register" class="zen-btn-primary px-8 py-3 text-lg zen-hover-lift">
          Start Creating
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/browse-professionals" class="zen-btn-outline px-8 py-3 text-lg zen-hover-lift">
          Discover Talent
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </a>
      </div>
      
      <!-- Zen Browser inspired feature highlights -->
      <div class="mx-auto max-w-3xl zen-animate-in" style="animation-delay: 0.3s;">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
          {features.map((feature, index) => (
            <div class="zen-card zen-hover-lift p-4 text-center" style={`animation-delay: ${0.4 + index * 0.1}s;`}>
              <div class="mb-2 text-sm font-medium text-muted-foreground">
                {feature}
              </div>
              <div class="h-1 w-full bg-gradient-to-r from-primary to-accent rounded-full opacity-20"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Zen Browser inspired stats section -->
    <div class="mx-auto max-w-5xl zen-animate-in" style="animation-delay: 0.5s;">
      <div class="zen-glass rounded-2xl p-8 zen-hover-lift">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="zen-hover-scale">
            <div class="text-3xl font-bold zen-gradient-text mb-2">10K+</div>
            <div class="text-sm text-muted-foreground">Creative Professionals</div>
          </div>
          <div class="zen-hover-scale">
            <div class="text-3xl font-bold zen-gradient-text mb-2">5K+</div>
            <div class="text-sm text-muted-foreground">Successful Events</div>
          </div>
          <div class="zen-hover-scale">
            <div class="text-3xl font-bold zen-gradient-text mb-2">50+</div>
            <div class="text-sm text-muted-foreground">Cities Worldwide</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Zen Browser inspired scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 zen-animate-in" style="animation-delay: 0.6s;">
    <div class="flex flex-col items-center space-y-2 text-muted-foreground">
      <span class="text-xs font-medium">Scroll to explore</span>
      <svg class="w-5 h-5 animate-bounce-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </div>
</section>

<style>
  /* Zen Browser inspired hero animations */
  .zen-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Zen Browser inspired gradient animations */
  .zen-gradient {
    background: linear-gradient(135deg, 
      hsl(var(--background)) 0%, 
      hsl(var(--background)) 50%, 
      hsl(var(--muted)) 100%
    );
  }

  /* Zen Browser inspired floating animations */
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-10px) rotate(1deg); }
    66% { transform: translateY(-5px) rotate(-1deg); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* Zen Browser inspired text animations */
  .zen-animate-in {
    animation: zen-fade-in-up 0.6s ease-out forwards;
    opacity: 0;
  }

  @keyframes zen-fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Zen Browser inspired hover effects */
  .zen-stats-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  /* Zen Browser inspired responsive design */
  @media (max-width: 640px) {
    .zen-hero {
      min-height: 80vh;
      padding-top: 4rem;
    }
  }

  /* Zen Browser inspired glass morphism enhancement */
  .zen-glass {
    backdrop-filter: blur(20px);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .dark .zen-glass {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired performance optimization */
  .zen-hero * {
    will-change: transform;
  }

  .zen-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(circle at 25% 25%, rgba(59, 130, 246, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 75% 75%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
    pointer-events: none;
  }
</style>

<script>
  // Zen Browser inspired scroll-triggered animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -100px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animationPlayState = 'running';
      }
    });
  }, observerOptions);

  // Observe all animated elements
  document.querySelectorAll('.zen-animate-in').forEach(el => {
    el.style.animationPlayState = 'paused';
    observer.observe(el);
  });

  // Zen Browser inspired parallax effect
  const parallaxElements = document.querySelectorAll('.animate-float');
  let ticking = false;

  function updateParallax() {
    const scrollY = window.pageYOffset;
    
    parallaxElements.forEach((element, index) => {
      const speed = 0.1 + (index * 0.05);
      const yPos = -(scrollY * speed);
      element.style.transform = `translateY(${yPos}px)`;
    });
    
    ticking = false;
  }

  function requestTick() {
    if (!ticking) {
      requestAnimationFrame(updateParallax);
      ticking = true;
    }
  }

  // Throttle scroll events for better performance
  window.addEventListener('scroll', requestTick, { passive: true });

  // Zen Browser inspired reduced motion support
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  
  if (prefersReducedMotion.matches) {
    document.querySelectorAll('.animate-float, .animate-bounce-subtle').forEach(el => {
      el.style.animation = 'none';
    });
  }
</script>
