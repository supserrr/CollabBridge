---
import { Image } from 'astro:assets';
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-600 via-brand-700 to-brand-800">
  <div class="absolute inset-0 bg-black/20"></div>
  
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="h-full w-full" fill="currentColor" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="10" cy="10" r="2" fill="white" opacity="0.3"></circle>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-pattern)"></rect>
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="text-center">
      <!-- Logo/Brand -->
      <div class="mb-8 inline-flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 backdrop-blur-sm">
          <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2L2 7v10c0 5.55 3.84 9.739 9 11 5.16-1.261 9-5.45 9-11V7l-10-5z"/>
          </svg>
        </div>
        <span class="text-2xl font-bold text-white">CollabBridge</span>
      </div>

      <!-- Main Heading -->
      <h1 class="mb-6 text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
        Connect. Create.
        <span class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent">
          Celebrate.
        </span>
      </h1>
      
      <p class="mx-auto mb-10 max-w-2xl text-xl text-brand-100">
        Bridge the gap between event planners and talented creative professionals. 
        Find the perfect team for your next unforgettable event.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a 
          href="/register?role=event-planner"
          class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-lg font-semibold text-brand-700 shadow-lg transition-all hover:bg-gray-50 hover:shadow-xl hover:-translate-y-0.5"
        >
          Find Creative Professionals
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        
        <a 
          href="/register?role=creative-professional"
          class="inline-flex items-center justify-center rounded-lg border-2 border-white/30 bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 hover:-translate-y-0.5"
        >
          Join as Creative Pro
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-2 gap-8 sm:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-white">10K+</div>
          <div class="text-sm text-brand-200">Active Professionals</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">5K+</div>
          <div class="text-sm text-brand-200">Events Completed</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">98%</div>
          <div class="text-sm text-brand-200">Success Rate</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">4.9★</div>
          <div class="text-sm text-brand-200">Average Rating</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>
