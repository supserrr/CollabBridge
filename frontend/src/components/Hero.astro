---
// No imports needed if not using Image component
---

<section class="bg-gradient-to-br from-brand-600 via-brand-700 to-brand-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Connect. Create. <span class="text-brand-200">Collaborate.</span>
      </h1>
      <p class="text-xl md:text-2xl mb-8 text-brand-100 max-w-3xl mx-auto">
        The platform where event planners discover amazing creative professionals 
        and talented artists find their next opportunity.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/register" 
          class="bg-white text-brand-700 px-8 py-3 rounded-lg font-semibold hover:bg-brand-50 transition-colors"
        >
          Get Started
        </a>
        <a 
          href="/browse" 
          class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-brand-700 transition-colors"
        >
          Browse Talent
        </a>
      </div>
    </div>
  </div>
</section>