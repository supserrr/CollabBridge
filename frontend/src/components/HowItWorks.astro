---
const steps = [
  {
    number: '01',
    title: 'Create Your Space',
    description: 'Build a mindful profile that reflects your authentic professional self. Share your creative vision with intention.',
    icon: 'zen-profile',
    color: 'from-primary/80 to-accent/60'
  },
  {
    number: '02',
    title: 'Mindful Discovery',
    description: 'Explore opportunities and talent through our calm, focused interface. Quality connections over quantity.',
    icon: 'zen-discover',
    color: 'from-accent/80 to-primary/60'
  },
  {
    number: '03',
    title: 'Peaceful Collaboration',
    description: 'Communicate with clarity and purpose. Our distraction-free environment fosters meaningful conversations.',
    icon: 'zen-collaborate',
    color: 'from-primary/60 to-accent/80'
  },
  {
    number: '04',
    title: 'Create with Purpose',
    description: 'Bring your shared vision to life in a supportive environment. Build lasting professional relationships.',
    icon: 'zen-create',
    color: 'from-accent/60 to-primary/80'
  }
];
---

<section class="relative zen-process-section">
  <!-- Zen Browser inspired background -->
  <div class="absolute inset-0 bg-gradient-to-br from-muted/30 via-background to-muted/30"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_25%,rgba(59,130,246,0.05),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_75%,rgba(139,92,246,0.05),transparent_50%)]"></div>
  
  <div class="relative zen-container">
    <!-- Zen Browser inspired section header -->
    <div class="text-center mb-20 zen-animate-in">
      <h2 class="zen-text-balance text-3xl font-bold tracking-tight text-foreground sm:text-4xl md:text-5xl mb-4">
        Your Journey to <span class="zen-gradient-text">Mindful</span> Collaboration
      </h2>
      <p class="zen-text-balance max-w-2xl mx-auto text-lg text-muted-foreground">
        Four simple steps to create meaningful professional connections in a calm, focused environment
      </p>
    </div>

    <!-- Zen Browser inspired process steps -->
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        {steps.map((step, index) => (
          <div class="relative text-center zen-animate-in" style={`animation-delay: ${index * 0.2}s;`}>
            {/* Zen Browser inspired connection line */}
            {index < steps.length - 1 && (
              <div class="absolute left-1/2 top-20 hidden h-0.5 w-full bg-gradient-to-r from-primary/30 to-accent/30 lg:block zen-connection-line"></div>
            )}
            
            {/* Zen Browser inspired step circle */}
            <div class="relative z-10 mx-auto mb-8 zen-hover-lift">
              <div class={`flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br ${step.color} zen-glass mx-auto`}>
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {step.icon === 'zen-profile' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  )}
                  {step.icon === 'zen-discover' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  )}
                  {step.icon === 'zen-collaborate' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                  )}
                  {step.icon === 'zen-create' && (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  )}
                </svg>
              </div>
              
              {/* Zen Browser inspired step number */}
              <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 bg-foreground text-background text-xs font-bold px-3 py-1 rounded-full zen-step-number">
                {step.number}
              </div>
            </div>
            
            {/* Zen Browser inspired step content */}
            <div class="zen-card p-6 zen-hover-lift">
              <h3 class="mb-4 text-xl font-semibold text-foreground">
                {step.title}
              </h3>
              <p class="text-muted-foreground zen-text-balance">
                {step.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Zen Browser inspired call-to-action -->
    <div class="text-center mt-20 zen-animate-in" style="animation-delay: 0.8s;">
      <div class="zen-glass rounded-2xl p-8 max-w-2xl mx-auto">
        <p class="text-muted-foreground mb-6">
          Ready to begin your mindful collaboration journey?
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/auth/register" class="zen-btn-primary px-6 py-3 zen-hover-lift">
            Start Creating
          </a>
          <a href="/about" class="zen-btn-outline px-6 py-3 zen-hover-lift">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Zen Browser inspired process section */
  .zen-process-section {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
    background: linear-gradient(135deg, 
      hsl(var(--background)) 0%, 
      hsl(var(--muted)/0.2) 50%, 
      hsl(var(--background)) 100%
    );
  }

  /* Zen Browser inspired connection line animation */
  .zen-connection-line {
    position: relative;
    overflow: hidden;
  }

  .zen-connection-line::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, hsl(var(--primary)), transparent);
    animation: zen-flow 3s ease-in-out infinite;
  }

  @keyframes zen-flow {
    0%, 100% { left: -100%; }
    50% { left: 100%; }
  }

  /* Zen Browser inspired step number styling */
  .zen-step-number {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    background: linear-gradient(45deg, hsl(var(--primary)), hsl(var(--accent)));
    color: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Zen Browser inspired glass morphism enhancement */
  .zen-glass {
    backdrop-filter: blur(20px);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
  }

  .dark .zen-glass {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px 0 rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired hover effects */
  .zen-hover-lift:hover {
    transform: translateY(-4px);
    transition: transform 0.3s ease;
  }

  .zen-card:hover {
    box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.1);
  }

  .dark .zen-card:hover {
    box-shadow: 0 20px 40px -12px rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired animations */
  .zen-animate-in {
    animation: zen-fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  @keyframes zen-fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Zen Browser inspired responsive design */
  @media (max-width: 1024px) {
    .zen-connection-line {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .zen-process-section {
      padding: 4rem 0;
    }
  }

  /* Zen Browser inspired accessibility */
  @media (prefers-reduced-motion: reduce) {
    .zen-animate-in,
    .zen-flow {
      animation: none;
    }
    
    .zen-hover-lift:hover {
      transform: none;
    }
  }

  /* Zen Browser inspired performance optimization */
  .zen-process-section * {
    will-change: transform;
  }
</style>

<script>
  // Zen Browser inspired scroll-triggered animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animationPlayState = 'running';
      }
    });
  }, observerOptions);

  // Observe all animated elements
  document.querySelectorAll('.zen-animate-in').forEach(el => {
    el.style.animationPlayState = 'paused';
    observer.observe(el);
  });

  // Zen Browser inspired step interaction
  document.querySelectorAll('.zen-card').forEach((card, index) => {
    card.addEventListener('mouseenter', function() {
      // Subtle highlight effect
      this.style.background = 'rgba(255, 255, 255, 0.15)';
      this.style.borderColor = 'rgba(255, 255, 255, 0.3)';
    });
    
    card.addEventListener('mouseleave', function() {
      this.style.background = 'rgba(255, 255, 255, 0.1)';
      this.style.borderColor = 'rgba(255, 255, 255, 0.2)';
    });
  });

  // Zen Browser inspired connection line animation trigger
  const connectionLines = document.querySelectorAll('.zen-connection-line');
  
  connectionLines.forEach((line, index) => {
    // Stagger the connection line animations
    setTimeout(() => {
      line.style.animationDelay = `${index * 0.5}s`;
    }, 1000);
  });
</script>
