---

<section class="bg-brand-700">
  <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Ready to Create Something Amazing?
      </h2>
      <p class="mt-6 text-xl text-brand-100">
        Join thousands of event planners and creative professionals already using CollabBridge
      </p>
      
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a 
          href="/register"
          class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-lg font-semibold text-brand-700 shadow-lg transition-all hover:bg-gray-50 hover:shadow-xl hover:-translate-y-0.5"
        >
          Get Started Today
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        
        <a 
          href="/browse"
          class="inline-flex items-center justify-center rounded-lg border-2 border-white/30 bg-white/10 px-8 py-4 text-lg font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 hover:-translate-y-0.5"
        >
          Browse Professionals
        </a>
      </div>
      
      <!-- Trust Indicators -->
      <div class="mt-16 text-center">
        <p class="text-sm text-brand-200">Trusted by professionals worldwide</p>
        <div class="mt-6 flex items-center justify-center space-x-8 opacity-60">
          <!-- Add partner/client logos here -->
          <div class="h-8 w-20 rounded bg-white/20"></div>
          <div class="h-8 w-20 rounded bg-white/20"></div>
          <div class="h-8 w-20 rounded bg-white/20"></div>
          <div class="h-8 w-20 rounded bg-white/20"></div>
        </div>
      </div>
    </div>
  </div>
</section>
