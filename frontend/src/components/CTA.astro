<section class="relative zen-cta-section">
  <!-- Zen Browser inspired gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-background to-accent/10"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.1),transparent_70%)]"></div>
  
  <!-- Zen Browser inspired floating elements -->
  <div class="absolute top-20 left-20 w-32 h-32 bg-gradient-to-r from-primary/20 to-accent/20 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-20 right-20 w-40 h-40 bg-gradient-to-r from-accent/20 to-primary/20 rounded-full blur-3xl animate-float" style="animation-delay: 2s;"></div>
  
  <div class="relative zen-container">
    <div class="zen-glass rounded-3xl p-12 md:p-16 text-center max-w-4xl mx-auto zen-animate-in">
      <!-- Zen Browser inspired main heading -->
      <h2 class="zen-text-balance text-3xl font-bold tracking-tight text-foreground sm:text-4xl md:text-5xl mb-6">
        Ready to Create in a 
        <span class="zen-gradient-text">Calmer Space</span>?
      </h2>
      
      <!-- Zen Browser inspired subtitle -->
      <p class="zen-text-balance text-xl text-muted-foreground max-w-2xl mx-auto mb-10">
        Join a mindful community of event planners and creative professionals 
        who value quality connections over quantity.
      </p>
      
      <!-- Zen Browser inspired CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a 
          href="/auth/register"
          class="zen-btn-primary px-8 py-4 text-lg zen-hover-lift"
        >
          Begin Your Journey
          <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        
        <a 
          href="/browse-professionals"
          class="zen-btn-outline px-8 py-4 text-lg zen-hover-lift"
        >
          <svg class="mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Explore Talent
        </a>
      </div>
      
      <!-- Zen Browser inspired trust indicators -->
      <div class="text-center">
        <p class="text-sm text-muted-foreground mb-6">
          Trusted by mindful professionals worldwide
        </p>
        
        <!-- Zen Browser inspired stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-2xl mx-auto">
          <div class="zen-stat-card p-4 zen-hover-scale">
            <div class="text-2xl font-bold zen-gradient-text mb-1">99%</div>
            <div class="text-xs text-muted-foreground">Satisfaction</div>
          </div>
          <div class="zen-stat-card p-4 zen-hover-scale">
            <div class="text-2xl font-bold zen-gradient-text mb-1">50+</div>
            <div class="text-xs text-muted-foreground">Countries</div>
          </div>
          <div class="zen-stat-card p-4 zen-hover-scale">
            <div class="text-2xl font-bold zen-gradient-text mb-1">24/7</div>
            <div class="text-xs text-muted-foreground">Support</div>
          </div>
          <div class="zen-stat-card p-4 zen-hover-scale">
            <div class="text-2xl font-bold zen-gradient-text mb-1">100K+</div>
            <div class="text-xs text-muted-foreground">Connections</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Zen Browser inspired testimonial -->
    <div class="mt-16 text-center zen-animate-in" style="animation-delay: 0.2s;">
      <blockquote class="zen-glass rounded-xl p-8 max-w-2xl mx-auto">
        <p class="text-lg text-muted-foreground italic mb-4">
          "CollabBridge transformed how I connect with creatives. The calm, focused environment 
          helps me build authentic professional relationships without the noise."
        </p>
        <footer class="text-sm text-muted-foreground">
          — Sarah Chen, Event Planner
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<style>
  /* Zen Browser inspired CTA section */
  .zen-cta-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
    background: linear-gradient(135deg, 
      hsl(var(--background)) 0%, 
      hsl(var(--muted)/0.5) 50%, 
      hsl(var(--background)) 100%
    );
  }

  /* Zen Browser inspired floating animation */
  @keyframes float {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg) scale(1); 
    }
    33% { 
      transform: translateY(-15px) rotate(2deg) scale(1.05); 
    }
    66% { 
      transform: translateY(-8px) rotate(-1deg) scale(0.98); 
    }
  }

  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  /* Zen Browser inspired stat cards */
  .zen-stat-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .dark .zen-stat-card {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .zen-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .dark .zen-stat-card:hover {
    box-shadow: 0 10px 25px -5px rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired glass morphism enhancement */
  .zen-glass {
    backdrop-filter: blur(20px);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
  }

  .dark .zen-glass {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px 0 rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired hover effects */
  .zen-hover-scale:hover {
    transform: scale(1.05);
    transition: transform 0.3s ease;
  }

  /* Zen Browser inspired animations */
  .zen-animate-in {
    animation: zen-fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  @keyframes zen-fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Zen Browser inspired responsive design */
  @media (max-width: 768px) {
    .zen-cta-section {
      padding: 4rem 0;
    }
    
    .zen-glass {
      margin: 0 1rem;
      padding: 2rem;
    }
  }

  /* Zen Browser inspired performance optimization */
  .zen-cta-section * {
    will-change: transform;
  }

  /* Zen Browser inspired accessibility */
  @media (prefers-reduced-motion: reduce) {
    .animate-float,
    .zen-animate-in {
      animation: none;
    }
    
    .zen-hover-lift:hover,
    .zen-hover-scale:hover {
      transform: none;
    }
  }
</style>

<script>
  // Zen Browser inspired scroll-triggered animation
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -100px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animationPlayState = 'running';
      }
    });
  }, observerOptions);

  // Observe CTA elements
  document.querySelectorAll('.zen-animate-in').forEach(el => {
    el.style.animationPlayState = 'paused';
    observer.observe(el);
  });

  // Zen Browser inspired button interaction enhancement
  document.querySelectorAll('.zen-btn-primary, .zen-btn-outline').forEach(button => {
    button.addEventListener('mouseenter', function(e) {
      this.style.transform = 'translateY(-2px) scale(1.02)';
    });
    
    button.addEventListener('mouseleave', function(e) {
      this.style.transform = 'translateY(0) scale(1)';
    });
  });

  // Zen Browser inspired parallax effect for floating elements
  const parallaxElements = document.querySelectorAll('.animate-float');
  let ticking = false;

  function updateParallax() {
    const scrollY = window.pageYOffset;
    const windowHeight = window.innerHeight;
    
    parallaxElements.forEach((element, index) => {
      const rect = element.getBoundingClientRect();
      const elementTop = rect.top + scrollY;
      const elementVisible = (elementTop < scrollY + windowHeight) && (elementTop + rect.height > scrollY);
      
      if (elementVisible) {
        const speed = 0.1 + (index * 0.05);
        const yPos = -(scrollY * speed);
        element.style.transform = `translateY(${yPos}px)`;
      }
    });
    
    ticking = false;
  }

  function requestTick() {
    if (!ticking) {
      requestAnimationFrame(updateParallax);
      ticking = true;
    }
  }

  window.addEventListener('scroll', requestTick, { passive: true });
</script>
