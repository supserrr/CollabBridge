<section style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 6rem 0; background: linear-gradient(135deg, #f4f1eb 0%, rgba(244, 241, 235, 0.9) 50%, #f4f1eb 100%); position: relative;">
  <!-- Zen Browser inspired floating elements -->
  <div style="position: absolute; top: 20px; left: 20px; width: 8rem; height: 8rem; background: linear-gradient(to right, rgba(239, 119, 68, 0.2), rgba(239, 119, 68, 0.1)); border-radius: 50%; filter: blur(48px); animation: float 6s ease-in-out infinite;"></div>
  <div style="position: absolute; bottom: 20px; right: 20px; width: 10rem; height: 10rem; background: linear-gradient(to right, rgba(239, 119, 68, 0.1), rgba(239, 119, 68, 0.2)); border-radius: 50%; filter: blur(48px); animation: float 6s ease-in-out infinite 2s;"></div>
  
  <div style="position: relative; max-width: 72rem; margin: 0 auto; padding: 0 1.5rem;">
    <div style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 1.5rem; padding: 3rem 4rem; text-align: center; max-width: 64rem; margin: 0 auto; border: 1px solid rgba(45, 37, 32, 0.1); box-shadow: 0 8px 32px rgba(45, 37, 32, 0.1);">
      <!-- Zen Browser inspired main heading -->
      <h2 style="font-size: 3rem; font-weight: 700; color: #2d2520; margin-bottom: 1.5rem; letter-spacing: -0.025em; line-height: 1.1;">
        Ready to Create in a 
        <span style="background: linear-gradient(135deg, #ef7744, #d4651f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Calmer Space</span>?
      </h2>
      
      <!-- Zen Browser inspired subtitle -->
      <p style="font-size: 1.25rem; color: #6b5f47; max-width: 32rem; margin: 0 auto 2.5rem; line-height: 1.6;">
        Join a mindful community of event planners and creative professionals 
        who value quality connections over quantity.
      </p>
      
      <!-- Zen Browser inspired CTA buttons -->
      <div style="display: flex; flex-direction: column; gap: 1rem; justify-content: center; margin-bottom: 3rem;">
        <a 
          href="/auth/register"
          style="display: inline-flex; align-items: center; justify-content: center; background-color: #ef7744; color: white; padding: 1rem 2rem; font-size: 1.125rem; border-radius: 0.75rem; text-decoration: none; font-weight: 600; transition: all 0.3s ease; border: none; box-shadow: 0 4px 12px rgba(239, 119, 68, 0.3);"
          class="cta-primary"
        >
          Begin Your Journey
          <svg style="margin-left: 0.5rem; height: 1.25rem; width: 1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        
        <a 
          href="/browse-professionals"
          style="display: inline-flex; align-items: center; justify-content: center; background-color: transparent; color: #2d2520; padding: 1rem 2rem; font-size: 1.125rem; border-radius: 0.75rem; text-decoration: none; font-weight: 600; transition: all 0.3s ease; border: 2px solid #ef7744;"
          class="cta-outline"
        >
          <svg style="margin-right: 0.5rem; height: 1.25rem; width: 1.25rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Explore Talent
        </a>
      </div>
      
      <!-- Zen Browser inspired trust indicators -->
      <div style="text-align: center;">
        <p style="font-size: 0.875rem; color: #6b5f47; margin-bottom: 1.5rem;">
          Trusted by mindful professionals worldwide
        </p>
        
        <!-- Zen Browser inspired stats -->
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 32rem; margin: 0 auto;">
          <div style="background: rgba(255, 255, 255, 0.5); padding: 1rem; border-radius: 0.75rem; border: 1px solid rgba(45, 37, 32, 0.1); transition: all 0.3s ease;" class="stat-card">
            <div style="font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #ef7744, #d4651f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">99%</div>
            <div style="font-size: 0.75rem; color: #6b5f47;">Satisfaction</div>
          </div>
          <div style="background: rgba(255, 255, 255, 0.5); padding: 1rem; border-radius: 0.75rem; border: 1px solid rgba(45, 37, 32, 0.1); transition: all 0.3s ease;" class="stat-card">
            <div style="font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #ef7744, #d4651f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">50+</div>
            <div style="font-size: 0.75rem; color: #6b5f47;">Countries</div>
          </div>
          <div style="background: rgba(255, 255, 255, 0.5); padding: 1rem; border-radius: 0.75rem; border: 1px solid rgba(45, 37, 32, 0.1); transition: all 0.3s ease;" class="stat-card">
            <div style="font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #ef7744, #d4651f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">24/7</div>
            <div style="font-size: 0.75rem; color: #6b5f47;">Support</div>
          </div>
          <div style="background: rgba(255, 255, 255, 0.5); padding: 1rem; border-radius: 0.75rem; border: 1px solid rgba(45, 37, 32, 0.1); transition: all 0.3s ease;" class="stat-card">
            <div style="font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #ef7744, #d4651f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 0.25rem;">100K+</div>
            <div style="font-size: 0.75rem; color: #6b5f47;">Connections</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Zen Browser inspired testimonial -->
    <div style="margin-top: 4rem; text-align: center;">
      <blockquote style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border-radius: 0.75rem; padding: 2rem; max-width: 32rem; margin: 0 auto; border: 1px solid rgba(45, 37, 32, 0.1);">
        <p style="font-size: 1.125rem; color: #6b5f47; font-style: italic; margin-bottom: 1rem; line-height: 1.6;">
          "CollabBridge transformed how I connect with creatives. The calm, focused environment 
          helps me build authentic professional relationships without the noise."
        </p>
        <footer style="font-size: 0.875rem; color: #6b5f47;">
          — Sarah Chen, Event Planner
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<style>
  /* Zen Browser inspired floating animation */
  @keyframes float {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg) scale(1); 
    }
    33% { 
      transform: translateY(-15px) rotate(2deg) scale(1.05); 
    }
    66% { 
      transform: translateY(-8px) rotate(-1deg) scale(0.98); 
    }
  }

  /* Zen Browser inspired hover effects */
  .cta-primary:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 24px rgba(239, 119, 68, 0.4);
    background-color: #d4651f;
  }

  .cta-outline:hover {
    background-color: #ef7744;
    color: white;
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 24px rgba(239, 119, 68, 0.3);
  }

  .stat-card:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 4px 16px rgba(45, 37, 32, 0.15);
    background: rgba(255, 255, 255, 0.8);
  }

  /* Responsive adjustments */
  @media (min-width: 640px) {
    section > div > div:first-child {
      display: flex !important;
      flex-direction: row !important;
      gap: 1rem !important;
    }
    
    section > div > div > div:nth-child(4) > div {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 2rem !important;
    }
    
    section {
      padding: 4rem 0 !important;
    }
    
    section > div > div:first-child {
      padding: 2rem !important;
    }
  }

  @media (min-width: 1024px) {
    h2 {
      font-size: 4rem !important;
    }
  }
</style>

  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  /* Zen Browser inspired stat cards */
  .zen-stat-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .dark .zen-stat-card {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .zen-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .dark .zen-stat-card:hover {
    box-shadow: 0 10px 25px -5px rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired glass morphism enhancement */
  .zen-glass {
    backdrop-filter: blur(20px);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
  }

  .dark .zen-glass {
    background: rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px 0 rgba(255, 255, 255, 0.1);
  }

  /* Zen Browser inspired hover effects */
  .zen-hover-scale:hover {
    transform: scale(1.05);
    transition: transform 0.3s ease;
  }

  /* Zen Browser inspired animations */
  .zen-animate-in {
    animation: zen-fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  @keyframes zen-fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Zen Browser inspired responsive design */
  @media (max-width: 768px) {
    .zen-cta-section {
      padding: 4rem 0;
    }
    
    .zen-glass {
      margin: 0 1rem;
      padding: 2rem;
    }
  }

  /* Zen Browser inspired performance optimization */
  .zen-cta-section * {
    will-change: transform;
  }

  /* Zen Browser inspired accessibility */
  @media (prefers-reduced-motion: reduce) {
    .animate-float,
    .zen-animate-in {
      animation: none;
    }
    
    .zen-hover-lift:hover,
    .zen-hover-scale:hover {
      transform: none;
    }
  }
</style>

<script>
  // Zen Browser inspired scroll-triggered animation
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -100px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.animationPlayState = 'running';
      }
    });
  }, observerOptions);

  // Observe CTA elements
  document.querySelectorAll('.zen-animate-in').forEach(el => {
    el.style.animationPlayState = 'paused';
    observer.observe(el);
  });

  // Zen Browser inspired button interaction enhancement
  document.querySelectorAll('.zen-btn-primary, .zen-btn-outline').forEach(button => {
    button.addEventListener('mouseenter', function(e) {
      this.style.transform = 'translateY(-2px) scale(1.02)';
    });
    
    button.addEventListener('mouseleave', function(e) {
      this.style.transform = 'translateY(0) scale(1)';
    });
  });

  // Zen Browser inspired parallax effect for floating elements
  const parallaxElements = document.querySelectorAll('.animate-float');
  let ticking = false;

  function updateParallax() {
    const scrollY = window.pageYOffset;
    const windowHeight = window.innerHeight;
    
    parallaxElements.forEach((element, index) => {
      const rect = element.getBoundingClientRect();
      const elementTop = rect.top + scrollY;
      const elementVisible = (elementTop < scrollY + windowHeight) && (elementTop + rect.height > scrollY);
      
      if (elementVisible) {
        const speed = 0.1 + (index * 0.05);
        const yPos = -(scrollY * speed);
        element.style.transform = `translateY(${yPos}px)`;
      }
    });
    
    ticking = false;
  }

  function requestTick() {
    if (!ticking) {
      requestAnimationFrame(updateParallax);
      ticking = true;
    }
  }

  window.addEventListener('scroll', requestTick, { passive: true });
</script>
