---
import { getCurrentUser } from '@/utils/auth';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full zen-glass border-b border-border/50 backdrop-blur-md">
  <div class="zen-container">
    <div class="flex h-14 items-center justify-between">
      <!-- Logo - Zen Browser Inspired -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-3 zen-hover-scale group">
          <div class="relative">
            <img src="/icons/logo.svg" alt="CollabBridge" class="h-8 w-8 zen-dark-invert transition-transform duration-200 group-hover:scale-110" />
            <div class="absolute -inset-1 bg-gradient-to-r from-primary/20 to-accent/20 rounded-full blur opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>
          </div>
          <span class="text-xl font-bold zen-gradient-text">CollabBridge</span>
        </a>
      </div>

      <!-- Desktop Navigation - Zen Browser Style -->
      <nav class="hidden lg:flex lg:items-center lg:space-x-8">
        <a 
          href="/browse-professionals" 
          class={`zen-nav-item ${
            currentPath === '/browse-professionals' ? 'zen-nav-item-active' : ''
          } zen-hover-lift px-3 py-2 rounded-md transition-all duration-200`}
        >
          Find Talent
        </a>
        <a 
          href="/events" 
          class={`zen-nav-item ${
            currentPath === '/events' ? 'zen-nav-item-active' : ''
          } zen-hover-lift px-3 py-2 rounded-md transition-all duration-200`}
        >
          Browse Events
        </a>
        <a 
          href="/how-it-works" 
          class={`zen-nav-item ${
            currentPath === '/how-it-works' ? 'zen-nav-item-active' : ''
          } zen-hover-lift px-3 py-2 rounded-md transition-all duration-200`}
        >
          How It Works
        </a>
        <a 
          href="/pricing" 
          class={`zen-nav-item ${
            currentPath === '/pricing' ? 'zen-nav-item-active' : ''
          } zen-hover-lift px-3 py-2 rounded-md transition-all duration-200`}
        >
          Pricing
        </a>
      </nav>

      <!-- User Menu - Zen Browser Style -->
      <div class="flex items-center space-x-4">
        <!-- Theme Toggle Button -->
        <button 
          id="theme-toggle"
          class="zen-btn-ghost h-9 w-9 rounded-md zen-hover-lift" 
          aria-label="Toggle theme"
        >
          <svg class="h-4 w-4 rotate-0 scale-100 transition-all dark:-rotate-90 dark:scale-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="absolute h-4 w-4 rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- Auth buttons will be handled by React component -->
        <div id="header-auth" class="zen-animate-in">
          <!-- React component will be mounted here -->
        </div>
        
        <!-- Mobile menu button - Zen Browser Style -->
        <button 
          type="button" 
          class="lg:hidden zen-btn-ghost h-9 w-9 rounded-md zen-hover-lift"
          id="mobile-menu-button"
          aria-label="Toggle menu"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu - Zen Browser Style -->
  <div class="lg:hidden hidden zen-glass border-t border-border/50 backdrop-blur-md" id="mobile-menu">
    <div class="zen-container py-4">
      <nav class="flex flex-col space-y-2">
        <a href="/browse-professionals" class="zen-nav-item zen-hover-lift px-3 py-2 rounded-md transition-all duration-200">
          Find Talent
        </a>
        <a href="/events" class="zen-nav-item zen-hover-lift px-3 py-2 rounded-md transition-all duration-200">
          Browse Events
        </a>
        <a href="/how-it-works" class="zen-nav-item zen-hover-lift px-3 py-2 rounded-md transition-all duration-200">
          How It Works
        </a>
        <a href="/pricing" class="zen-nav-item zen-hover-lift px-3 py-2 rounded-md transition-all duration-200">
          Pricing
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  /* Zen Browser inspired header animations */
  .zen-logo-glow {
    animation: zenGlow 2s ease-in-out infinite alternate;
  }

  @keyframes zenGlow {
    0% { box-shadow: 0 0 20px rgba(59, 130, 246, 0.1); }
    100% { box-shadow: 0 0 30px rgba(59, 130, 246, 0.2); }
  }

  /* Zen Browser inspired mobile menu animation */
  #mobile-menu {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #mobile-menu.hidden {
    opacity: 0;
    transform: translateY(-10px);
  }

  #mobile-menu:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
  }

  /* Zen Browser inspired focus states */
  .zen-keyboard-navigation .zen-focus-ring:focus {
    outline: 2px solid hsl(var(--ring));
    outline-offset: 2px;
  }
</style>

<script>
  import { createRoot } from 'react-dom/client';
  import { createElement } from 'react';
  import HeaderAuth from './HeaderAuth';
  import DebugPanel from '../debug/DebugPanel';

  // Mount auth component with Zen animation
  const authContainer = document.getElementById('header-auth');
  if (authContainer) {
    const root = createRoot(authContainer);
    root.render(createElement(HeaderAuth));
  }

  // Mount debug panel in development
  if (import.meta.env.DEV) {
    const debugContainer = document.createElement('div');
    debugContainer.id = 'debug-panel';
    document.body.appendChild(debugContainer);
    
    const debugRoot = createRoot(debugContainer);
    debugRoot.render(createElement(DebugPanel));
  }

  // Zen Browser inspired theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('zen-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('zen-theme', 'dark');
      }
    });
  }

  // Zen Browser inspired mobile menu toggle with smooth animation
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      const isHidden = mobileMenu.classList.contains('hidden');
      
      if (isHidden) {
        mobileMenu.classList.remove('hidden');
        // Force reflow before animation
        mobileMenu.offsetHeight;
        mobileMenu.style.opacity = '1';
        mobileMenu.style.transform = 'translateY(0)';
      } else {
        mobileMenu.style.opacity = '0';
        mobileMenu.style.transform = 'translateY(-10px)';
        
        setTimeout(() => {
          mobileMenu.classList.add('hidden');
        }, 300);
      }
    });
  }

  // Zen Browser inspired smooth scroll enhancement
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Zen Browser inspired intersection observer for header
  const header = document.querySelector('header');
  let lastScrollY = window.scrollY;

  const handleScroll = () => {
    const currentScrollY = window.scrollY;
    
    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      // Scrolling down
      header?.classList.add('zen-header-hidden');
    } else {
      // Scrolling up
      header?.classList.remove('zen-header-hidden');
    }
    
    lastScrollY = currentScrollY;
  };

  // Throttle scroll events for better performance
  let ticking = false;
  const handleScrollThrottled = () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        handleScroll();
        ticking = false;
      });
      ticking = true;
    }
  };

  window.addEventListener('scroll', handleScrollThrottled, { passive: true });
</script>
