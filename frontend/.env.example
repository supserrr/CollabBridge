# API Configuration
PUBLIC_API_URL=http://localhost:3000/api
PUBLIC_FRONTEND_URL=http://localhost:4321

# Firebase Client Configuration
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# Cloudinary Configuration
PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
PUBLIC_CLOUDINARY_API_KEY=your_api_key

# App Configuration
PUBLIC_APP_NAME=CollabBridge
PUBLIC_APP_DESCRIPTION=Connect event planners with creative professionals
PUBLIC_MAX_FILE_SIZE=10485760
PUBLIC_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# Analytics (optional)
PUBLIC_GOOGLE_ANALYTICS_ID=your_ga_id
PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Feature Flags
PUBLIC_ENABLE_CHAT=true
PUBLIC_ENABLE_PAYMENTS=false
PUBLIC_ENABLE_NOTIFICATIONS=true
PUBLIC_ENABLE_REVIEWS=true

# Environment
NODE_ENV=development
PUBLIC_NODE_ENV=development
